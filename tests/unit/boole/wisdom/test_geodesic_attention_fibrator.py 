# PRUEBAS DE FASE 2 — ATENCIÓN COVARIANTE
# ══════════════════════════════════════════════════════════════════════════════
class TestPhase2CovariantAttention:
    """Verifica el mecanismo de atención levantado al fibrado covariante."""

    @pytest.fixture
    def geom_ctx(self, fibrator, base_metric, valid_torsion, dim):
        phase1 = fibrator._Phase1_GeometricFoundation(base_metric)
        return phase1.build_geometric_context(valid_torsion)

    def test_inner_product_reduces_to_euclidean_for_identity_metric(
        self, fibrator, Q_K_V, dim
    ):
        Q, K, _ = Q_K_V
        phase2 = fibrator._Phase2_CovariantAttention()
        # Con G = I, ⟨Q,K⟩_g = Q K^T (producto euclidiano)
        G_id = np.eye(dim)
        ip = phase2._covariant_inner_product(Q, K, G_id)
        expected = Q @ K.T
        assert np.allclose(ip, expected, atol=1e-12)

    def test_inner_product_symmetric(self, fibrator, Q_K_V, geom_ctx):
        Q, K, _ = Q_K_V
        phase2 = fibrator._Phase2_CovariantAttention()
        ip = phase2._covariant_inner_product(Q, K, geom_ctx.effective_metric)
        # No necesariamente simétrico en batch, pero debe ser finito
        assert np.all(np.isfinite(ip))

    def test_softmax_normalized(self, fibrator, Q_K_V, geom_ctx):
        Q, K, V = Q_K_V
        phase2 = fibrator._Phase2_CovariantAttention()
        weights, _ = phase2.compute_attention_weights(Q, K, V, geom_ctx)
        row_sums = np.sum(weights, axis=-1)
        assert np.allclose(row_sums, 1.0, atol=1e-10)

    def test_softmax_non_negative(self, fibrator, Q_K_V, geom_ctx):
        Q, K, V = Q_K_V
        phase2 = fibrator._Phase2_CovariantAttention()
        weights, _ = phase2.compute_attention_weights(Q, K, V, geom_ctx)
        assert np.all(weights >= 0.0)

    def test_softmax_stable_with_extreme_scores(self, fibrator, dim, geom_ctx):
        """Softmax debe manejar scores muy grandes sin overflow."""
        Q = np.full((1, dim), 1e3)
        K = np.full((1, dim), 1e3)
        V = np.zeros((1, dim))
        phase2 = fibrator._Phase2_CovariantAttention()
        weights, _ = phase2.compute_attention_weights(Q, K, V, geom_ctx)
        assert np.all(np.isfinite(weights))
        assert np.allclose(np.sum(weights), 1.0, atol=1e-10)

    def test_parallel_transport_preserves_shape(self, fibrator, Q_K_V, geom_ctx):
        Q, K, V = Q_K_V
        phase2 = fibrator._Phase2_CovariantAttention()
        V_transported = phase2._parallel_transport_batch(V, geom_ctx.parallel_transport)
        assert V_transported.shape == V.shape

    def test_geodesic_energy_non_negative(self, fibrator, Q_K_V, geom_ctx):
        Q, K, _ = Q_K_V
        phase2 = fibrator._Phase2_CovariantAttention()
        energy = phase2._geodesic_energy(Q, K, geom_ctx.effective_metric)
        assert energy >= 0.0

    def test_geodesic_energy_zero_for_identical_points(self, fibrator, dim, geom_ctx):
        Q = K = np.eye(dim)[:3]  # filas idénticas
        phase2 = fibrator._Phase2_CovariantAttention()
        energy = phase2._geodesic_energy(Q, K, geom_ctx.effective_metric)
        # diff = 0, por tanto energía = 0
        assert np.isclose(energy, 0.0, atol=1e-10)

    def test_temperature_scales_softmax_sharpness(
        self, fibrator, dim, geom_ctx
    ):
        """Temperatura baja → softmax más picudo."""
        scores = np.array([[1.0, 2.0, 3.0]])
        phase2 = fibrator._Phase2_CovariantAttention()
        sharp = phase2._stabilized_softmax(scores, temperature=0.1)
        smooth = phase2._stabilized_softmax(scores, temperature=10.0)
        # Distribución más picuda tiene mayor entropía invertida (menor entropía)
        ent_sharp = -np.sum(sharp * np.log(sharp + 1e-12))
        ent_smooth = -np.sum(smooth * np.log(smooth + 1e-12))
        assert ent_sharp < ent_smooth

    def test_compute_attention_returns_tuple(self, fibrator, Q_K_V, geom_ctx):
        Q, K, V = Q_K_V
        phase2 = fibrator._Phase2_CovariantAttention()
        result = phase2.compute_attention_weights(Q, K, V, geom_ctx)
        assert isinstance(result, tuple)
        assert len(result) == 2
        weights, energy = result
        assert np.all(np.isfinite(weights))
        assert np.isfinite(energy)


