                Q, K, V, valid_torsion, 0.0
            )

    def test_geometric_cache_hit(self, fibrator, Q_K_V, valid_torsion):
        """Llamadas sucesivas con la misma torsión deben usar la caché."""
        Q, K, V = Q_K_V
        # Primera llamada: poblar caché
        fibrator.project_covariant_attention(
            Q, K, V, valid_torsion, 0.1
        )
        # Segunda llamada con la misma torsión
        cache_key_before = fibrator._geom_cache_key
        fibrator.project_covariant_attention(
            Q, K, V, valid_torsion, 0.1
        )
        cache_key_after = fibrator._geom_cache_key
        assert cache_key_before == cache_key_after

    def test_geometric_cache_miss_on_new_torsion(
        self, fibrator, Q_K_V, dim
    ):
        """Una torsión distinta debe invalidar la caché."""
        Q, K, V = Q_K_V
        torsion1 = np.zeros((dim, dim, dim))
        torsion2 = np.ones((dim, dim, dim))
        # Antisimetrizar torsion2
        torsion2 = 0.5 * (torsion2 - np.transpose(torsion2, (0, 2, 1)))
        fibrator.project_covariant_attention(Q, K, V, torsion1, 0.1)
        key1 = fibrator._geom_cache_key
        fibrator.project_covariant_attention(Q, K, V, torsion2, 0.1)
        key2 = fibrator._geom_cache_key
        assert key1 != key2

    def test_lazy_initialization_of_phases(self, fibrator, Q_K_V, valid_torsion):
        """Las fases se instancian perezosamente en la primera llamada."""
        assert fibrator._phase1 is None
        assert fibrator._phase2 is None
        assert fibrator._phase3 is None
        Q, K, V = Q_K_V
        fibrator.project_covariant_attention(Q, K, V, valid_torsion, 0.1)
        assert fibrator._phase1 is not None
        assert fibrator._phase2 is not None
        assert fibrator._phase3 is not None

    def test_call_delegates_to_orchestrator(
        self, fibrator, Q_K_V, valid_torsion
    ):
        """``__call__`` debe comportarse idéntico al orquestador."""
        Q, K, V = Q_K_V
        result_call = fibrator(Q, K, V, valid_torsion, 0.1)
        result_method = fibrator.project_covariant_attention(
            Q, K, V, valid_torsion, 0.1
        )
        assert np.allclose(
            result_call.covariant_attention_weights,
            result_method.covariant_attention_weights
        )

    def test_zero_torsion_works(self, fibrator, Q_K_V, dim):
        Q, K, V = Q_K_V
        torsion_zero = np.zeros((dim, dim, dim))
        result = fibrator.project_covariant_attention(
            Q, K, V, torsion_zero, 0.1
        )
        assert isinstance(result, GeodesicPathResult)

    def test_high_action_vetoes_path(
        self, fibrator, Q_K_V, valid_torsion
    ):
        """Una energía de Dirichlet enorme debe vetar el camino."""
        Q, K, V = Q_K_V
        result = fibrator.project_covariant_attention(
            Q, K, V, valid_torsion, dirichlet_energy=1e6
        )
        # Con S_E >> ℏ, amplitud → 0 → veto
        # Nota: la energía efectiva es 0.5*(externa + geodésica), podría no vetar
        # Para garantizar el veto, usamos energía muy grande
        result_huge = fibrator.project_covariant_attention(
            Q, K, V, valid_torsion, dirichlet_energy=1e10
        )
        assert result_huge.is_path_viable is False
        assert np.allclose(result_huge.covariant_attention_weights, 0.0)


