# PRUEBAS DE SÍMBOLOS DE CHRISTOFFEL
# ══════════════════════════════════════════════════════════════════════════════
class TestChristoffelSymbols:
    """Verifica la estructura del envoltorio de Christoffel."""

    def test_valid_christoffel_accepted(self, dim: int):
        gamma = np.zeros((dim, dim, dim))
        christoffel = ChristoffelSymbols(gamma=gamma)
        assert christoffel.gamma.shape == (dim, dim, dim)

    def test_nan_rejected(self, dim: int):
        bad = np.zeros((dim, dim, dim))
        bad[0, 0, 0] = np.nan
        with pytest.raises(NumericalInstabilityError, match="NaN/Inf"):
            ChristoffelSymbols(gamma=bad)

    def test_wrong_shape_rejected(self):
        bad = np.zeros((3, 3, 4))
        with pytest.raises(NumericalInstabilityError, match="cúbica"):
            ChristoffelSymbols(gamma=bad)

    def test_covariant_derivative_zero_christoffel(self, dim: int):
        """Si Γ = 0, la derivada covariante debe ser nula."""
        gamma = np.zeros((dim, dim, dim))
        christoffel = ChristoffelSymbols(gamma=gamma)
        v = np.arange(dim, dtype=np.float64)
        deriv = christoffel.covariant_derivative(v)
        assert np.allclose(deriv, 0.0)

    def test_covariant_derivative_consistent(self, dim: int):
        """∇_v v con Γ = δ^μ_{νρ} c debe dar ||v||² en cada componente."""
        gamma = np.zeros((dim, dim, dim))
        # Γ^μ_{νρ} = δ_μν δ_ρ0
        gamma[:, :, 0] = np.eye(dim)
        christoffel = ChristoffelSymbols(gamma=gamma)
        v = np.ones(dim)
        deriv = christoffel.covariant_derivative(v)
        # esperado: sum_n v^n sum_p Γ^μ_{np} v^p = sum_n v^n Γ^μ_{n0} v^0 = v[μ] * 1
        assert np.allclose(deriv, v)

    def test_covariant_derivative_with_velocity(self, dim: int):
        """Si se especifica coords_velocity, debe usarlo en lugar de v."""
        gamma = np.zeros((dim, dim, dim))
        gamma[:, :, 0] = np.eye(dim)
        christoffel = ChristoffelSymbols(gamma=gamma)
        v = np.zeros(dim)
        w = np.ones(dim)
        deriv = christoffel.covariant_derivative(v, coords_velocity=w)
        # esperado: Γ^μ_{ν0} w^ν v^0 — con v=0, todo cero
        assert np.allclose(deriv, 0.0)


