# PRUEBAS DE INVARIANTES FÍSICOS
# ══════════════════════════════════════════════════════════════════════════════
class TestPhysicalInvariants:
    """Verifica invariantes físicos del sistema bajo distintas entradas."""

    def test_metric_determinant_positive(
        self, fibrator, Q_K_V, valid_torsion
    ):
        Q, K, V = Q_K_V
        fibrator.project_covariant_attention(Q, K, V, valid_torsion, 0.1)
        # Acceder a la fase 1 ya instanciada
        phase1 = fibrator._phase1
        G_eff = phase1.base_metric + FibratorConstants.KAPPA_RICCI * \
                phase1._compute_ricci_from_torsion(
                    TorsionTensor(components=valid_torsion)
                )
        # Después de proyección SDP
        eigvals, eigvecs = la.eigh(0.5 * (G_eff + G_eff.T))
        eigvals = np.maximum(eigvals, FibratorConstants.EPSILON_MACH)
        G_psd = (eigvecs * eigvals) @ eigvecs.T
        assert la.det(G_psd) > 0.0

    def test_attention_weights_sum_to_one_per_row(
        self, fibrator, Q_K_V, valid_torsion, batch_size
    ):
        """Invariante atencional: cada fila del batch suma a 1 (si es viable)."""
        Q, K, V = Q_K_V
        # Forzar viabilidad bajando el threshold
        result = fibrator.project_covariant_attention(
            Q, K, V, valid_torsion, 0.0
        )
        if result.is_path_viable:
            sums = np.sum(result.covariant_attention_weights, axis=-1)
            assert np.allclose(sums, 1.0, atol=1e-9)
        else:
            # Si fue vetado, todos los pesos son cero
            assert np.allclose(result.covariant_attention_weights, 0.0)

    def test_reproducibility_with_same_seed(
        self, fibrator, Q_K_V, valid_torsion
    ):
        """El sistema es determinista (no usa RNG en el camino principal)."""
        Q, K, V = Q_K_V
        result1 = fibrator.project_covariant_attention(
            Q, K, V, valid_torsion, 0.1
        )
        result2 = fibrator.project_covariant_attention(
            Q, K, V, valid_torsion, 0.1
        )
        assert np.allclose(
            result1.covariant_attention_weights,
            result2.covariant_attention_weights
        )
        assert result1.feynman_amplitude == result2.feynman_amplitude

    @pytest.mark.parametrize("dim_param", [2, 4, 8, 16])
    def test_scales_with_dimension(self, fibrator, dim_param):
        """El sistema debe operar correctamente en distintas dimensiones."""
        rng_local = np.random.default_rng(dim_param * 100)
        A = rng_local.standard_normal((dim_param, dim_param))
        G = A @ A.T + np.eye(dim_param)
        fibrator_dim = GeodesicAttentionFibrator(stratum=Stratum.WISDOM)
        fibrator_dim.G_base = fibrator_dim._validate_base_metric(G)
        Q = rng_local.standard_normal((2, dim_param))
        K = rng_local.standard_normal((2, dim_param))
        V = rng_local.standard_normal((2, dim_param))
        torsion = 0.5 * (
            rng_local.standard_normal((dim_param, dim_param, dim_param))
            - np.transpose(
                rng_local.standard_normal((dim_param, dim_param, dim_param)),
                (0, 2, 1)
            )
        )
        torsion = 0.5 * (torsion - np.transpose(torsion, (0, 2, 1)))
        result = fibrator_dim.project_covariant_attention(
            Q, K, V, torsion, 0.1
        )
        assert isinstance(result, GeodesicPathResult)
        assert np.all(np.isfinite(result.covariant_attention_weights))


