# PRUEBAS DE COMPATIBILIDAD MÉTRICA
# ══════════════════════════════════════════════════════════════════════════════
class TestMetricCompatibility:
    """Verifica la condición ∇_ρ g_{μν} = 0 en el transporte paralelo."""

    def test_parallel_transport_metric_compatibility_zero_christoffel(
        self, fibrator, base_metric, dim
    ):
        """Para Γ = 0, P = I y por tanto G = P^T G P exactamente."""
        phase1 = fibrator._Phase1_GeometricFoundation(base_metric)
        zero_torsion = np.zeros((dim, dim, dim))
        ctx = phase1.build_geometric_context(zero_torsion)
        G_transported = ctx.parallel_transport.T @ ctx.effective_metric @ ctx.parallel_transport
        residual = np.linalg.norm(
            ctx.effective_metric - G_transported, ord='fro'
        )
        # Con torsión nula, Γ = 0 → P = I → residual ≈ 0
        assert residual < 1e-9

    def test_parallel_transport_metric_compatibility_nonzero_torsion(
        self, fibrator, base_metric, valid_torsion
    ):
        """Para torsión no nula, la compatibilidad puede relajarse (sólo log)."""
        phase1 = fibrator._Phase1_GeometricFoundation(base_metric)
        ctx = phase1.build_geometric_context(valid_torsion)
        # No fallamos; sólo verificamos que el log se emita si residual > tol
        G_transported = ctx.parallel_transport.T @ ctx.effective_metric @ ctx.parallel_transport
        residual = np.linalg.norm(
            ctx.effective_metric - G_transported, ord='fro'
        )
        # El residual debe estar acotado
        assert residual < 1.0  # cota laxa de estabilidad


