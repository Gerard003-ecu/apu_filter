# PRUEBAS DE FASE 3 — INTEGRACIÓN DE FEYNMAN-KAC
# ══════════════════════════════════════════════════════════════════════════════
class TestPhase3FeynmanIntegration:
    """Verifica el cálculo de la acción, amplitud y veto cuántico."""

    def test_action_positive_components(self):
        phase3 = GeodesicAttentionFibrator._Phase3_FeynmanIntegration()
        action = phase3._compute_action(dirichlet_energy=1.0, torsion_norm_sq=0.5)
        assert np.isclose(action, 1.0 + 1.0 * 0.5)

    def test_action_rejects_negative_dirichlet(self):
        phase3 = GeodesicAttentionFibrator._Phase3_FeynmanIntegration()
        with pytest.raises(NumericalInstabilityError, match="negativa"):
            phase3._compute_action(dirichlet_energy=-1.0, torsion_norm_sq=0.0)

    def test_action_rejects_negative_torsion(self):
        phase3 = GeodesicAttentionFibrator._Phase3_FeynmanIntegration()
        with pytest.raises(NumericalInstabilityError, match="negativa"):
            phase3._compute_action(dirichlet_energy=1.0, torsion_norm_sq=-0.1)

    def test_feynman_amplitude_in_unit_interval(self):
        phase3 = GeodesicAttentionFibrator._Phase3_FeynmanIntegration()
        # Para acción positiva y ℏ > 0, amplitud ∈ (0, 1]
        for action in [0.0, 0.1, 1.0, 10.0, 100.0]:
            amp = phase3._compute_feynman_amplitude(action)
            assert 0.0 <= amp <= 1.0

    def test_feynman_amplitude_decays_with_action(self):
        phase3 = GeodesicAttentionFibrator._Phase3_FeynmanIntegration()
        amp_low = phase3._compute_feynman_amplitude(0.1)
        amp_high = phase3._compute_feynman_amplitude(10.0)
        assert amp_low > amp_high

    def test_feynman_amplitude_clipped_at_epsilon(self):
        """Para acciones enormes, amplitud → 0 (clip numérico)."""
        phase3 = GeodesicAttentionFibrator._Phase3_FeynmanIntegration()
        amp = phase3._compute_feynman_amplitude(1e10)
        assert amp == 0.0

    def test_viable_path_preserves_weights(self):
        phase3 = GeodesicAttentionFibrator._Phase3_FeynmanIntegration(
            amplitude_threshold=0.0
        )
        weights = np.array([[0.5, 0.5]])
        final, amp, action, viable = phase3.suppress_non_viable_paths(
            weights, dirichlet_energy=0.0
        )
        assert viable is True
        assert np.allclose(final, weights)

    def test_non_viable_path_annihilated(self):
        phase3 = GeodesicAttentionFibrator._Phase3_FeynmanIntegration(
            amplitude_threshold=0.999
        )
        weights = np.array([[0.5, 0.5]])
        # Con S_E=1.0 y ℏ=1e-3, amplitud = exp(-1000) ≈ 0 < 0.999
        final, amp, action, viable = phase3.suppress_non_viable_paths(
            weights, dirichlet_energy=1.0
        )
        assert viable is False
        assert np.allclose(final, 0.0)

    def test_torsion_penalty_increases_action(self):
        phase3_no = GeodesicAttentionFibrator._Phase3_FeynmanIntegration(torsion_penalty=0.0)
        phase3_yes = GeodesicAttentionFibrator._Phase3_FeynmanIntegration(torsion_penalty=5.0)
        action_no = phase3_no._compute_action(1.0, 1.0)
        action_yes = phase3_yes._compute_action(1.0, 1.0)
        assert action_yes > action_no


