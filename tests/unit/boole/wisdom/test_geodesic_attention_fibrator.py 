# PRUEBAS DE TENSOR DE TORSIÓN
# ══════════════════════════════════════════════════════════════════════════════
class TestTorsionTensor:
    """Verifica el envoltorio inmutable del tensor de torsión (1,2)."""

    def test_valid_torsion_accepted(self, valid_torsion: np.ndarray, dim: int):
        tensor = TorsionTensor(components=valid_torsion)
        assert tensor.components.shape == (dim, dim, dim)

    def test_wrong_shape_rejected(self):
        bad = np.zeros((3, 4, 3))
        with pytest.raises(NumericalInstabilityError, match="cúbica"):
            TorsionTensor(components=bad)

    def test_nan_rejected(self, dim: int):
        bad = np.zeros((dim, dim, dim))
        bad[0, 0, 0] = np.nan
        with pytest.raises(NumericalInstabilityError, match="NaN/Inf"):
            TorsionTensor(components=bad)

    def test_inf_rejected(self, dim: int):
        bad = np.zeros((dim, dim, dim))
        bad[0, 0, 0] = np.inf
        with pytest.raises(NumericalInstabilityError, match="NaN/Inf"):
            TorsionTensor(components=bad)

    def test_asymmetry_enforced(self, dim: int):
        # Tensor simétrico en (ν,ρ) debe ser rechazado
        sym = np.ones((dim, dim, dim))
        with pytest.raises(NumericalInstabilityError, match="antisimétrico"):
            TorsionTensor(components=sym)

    def test_immutability(self, valid_torsion: np.ndarray):
        tensor = TorsionTensor(components=valid_torsion)
        with pytest.raises(Exception):  # FrozenInstanceError de dataclass
            tensor.components = np.zeros_like(tensor.components)

    def test_zero_torsion_accepted(self, dim: int):
        zero = np.zeros((dim, dim, dim))
        tensor = TorsionTensor(components=zero)  # torsión trivial es válida
        assert np.allclose(tensor.components, 0.0)


