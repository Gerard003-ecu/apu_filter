# PRUEBAS DE VALIDACIÓN DE MÉTRICA BASE
# ══════════════════════════════════════════════════════════════════════════════
class TestBaseMetricValidation:
    """Verifica la proyección SDP de la métrica base en el constructor."""

    def test_identity_metric_preserved(self):
        fibrator = GeodesicAttentionFibrator(stratum=Stratum.WISDOM)
        fibrator.G_base = fibrator._validate_base_metric(np.eye(4))
        assert np.allclose(fibrator.G_base, np.eye(4))

    def test_non_psd_metric_projected_to_psd(self):
        """Una métrica con un autovalor negativo debe ser proyectada a SDP."""
        fibrator = GeodesicAttentionFibrator(stratum=Stratum.WISDOM)
        # Matriz con autovalor -0.5
        G = np.diag([1.0, 1.0, -0.5, 1.0])
        G_proj = fibrator._validate_base_metric(G)
        eigvals = la.eigvalsh(0.5 * (G_proj + G_proj.T))
        assert np.all(eigvals > 0.0)

    def test_wrong_shape_rejected(self):
        fibrator = GeodesicAttentionFibrator(stratum=Stratum.WISDOM)
        with pytest.raises(NumericalInstabilityError, match="\\(d,d\\)"):
            fibrator._validate_base_metric(np.zeros((3, 4)))

    def test_projection_preserves_symmetry(self):
        fibrator = GeodesicAttentionFibrator(stratum=Stratum.WISDOM)
        rng_local = np.random.default_rng(31)
        G = rng_local.standard_normal((5, 5))
        G_proj = fibrator._validate_base_metric(G)
        assert np.allclose(G_proj, G_proj.T, atol=1e-12)


