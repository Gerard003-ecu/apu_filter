# PRUEBAS DE FASE 1 — CIMIENTO GEOMÉTRICO
# ══════════════════════════════════════════════════════════════════════════════
class TestPhase1GeometricFoundation:
    """Verifica la construcción de la variedad Riemanniana con torsión."""

    def test_levi_civita_zero_when_no_adjacency(self, fibrator, base_metric):
        phase1 = fibrator._Phase1_GeometricFoundation(base_metric)
        gamma_lc = phase1._compute_levi_civita(base_metric)
        assert np.allclose(gamma_lc.gamma, 0.0)

    def test_ricci_symmetric_from_torsion(self, fibrator, base_metric, valid_torsion):
        phase1 = fibrator._Phase1_GeometricFoundation(base_metric)
        torsion = TorsionTensor(components=valid_torsion)
        ricci = phase1._compute_ricci_from_torsion(torsion)
        # Ric_{μν} debe ser simétrico por construcción
        assert np.allclose(ricci, ricci.T, atol=1e-12)

    def test_ricci_psd_with_tikhonov(self, fibrator, base_metric, valid_torsion):
        phase1 = fibrator._Phase1_GeometricFoundation(base_metric)
        torsion = TorsionTensor(components=valid_torsion)
        ricci = phase1._compute_ricci_from_torsion(torsion)
        # Debe ser PSD por la corrección ε·g
        eigvals = la.eigvalsh(0.5 * (ricci + ricci.T))
        assert np.all(eigvals >= 0.0)

    def test_contorsion_zero_for_zero_torsion(self, fibrator, base_metric, dim):
        phase1 = fibrator._Phase1_GeometricFoundation(base_metric)
        zero_torsion = TorsionTensor(components=np.zeros((dim, dim, dim)))
        levi_civita = ChristoffelSymbols(gamma=np.zeros((dim, dim, dim)))
        K = phase1._compute_contorsion(zero_torsion, levi_civita)
        assert np.allclose(K, 0.0)

    def test_contorsion_antisymmetric_in_lower_indices(
        self, fibrator, base_metric, valid_torsion, dim
    ):
        """K^μ_{νρ} debe ser antisimétrico en (ν,ρ)."""
        phase1 = fibrator._Phase1_GeometricFoundation(base_metric)
        torsion = TorsionTensor(components=valid_torsion)
        levi_civita = ChristoffelSymbols(gamma=np.zeros((dim, dim, dim)))
        K = phase1._compute_contorsion(torsion, levi_civita)
        assert np.allclose(K, -np.transpose(K, (0, 2, 1)), atol=1e-12)

    def test_effective_metric_psd(self, fibrator, base_metric, valid_torsion):
        phase1 = fibrator._Phase1_GeometricFoundation(base_metric)
        ctx = phase1.build_geometric_context(valid_torsion)
        eigvals = la.eigvalsh(0.5 * (ctx.effective_metric + ctx.effective_metric.T))
        assert np.all(eigvals > 0.0)

    def test_effective_metric_symmetric(
        self, fibrator, base_metric, valid_torsion
    ):
        phase1 = fibrator._Phase1_GeometricFoundation(base_metric)
        ctx = phase1.build_geometric_context(valid_torsion)
        assert np.allclose(ctx.effective_metric, ctx.effective_metric.T, atol=1e-12)

    def test_ricci_scalar_trace_finite(
        self, fibrator, base_metric, valid_torsion
    ):
        phase1 = fibrator._Phase1_GeometricFoundation(base_metric)
        ctx = phase1.build_geometric_context(valid_torsion)
        assert np.isfinite(ctx.ricci_scalar_trace)

    def test_parallel_transport_is_square(
        self, fibrator, base_metric, valid_torsion, dim
    ):
        phase1 = fibrator._Phase1_GeometricFoundation(base_metric)
        ctx = phase1.build_geometric_context(valid_torsion)
        assert ctx.parallel_transport.shape == (dim, dim)

    def test_parallel_transport_initialized_as_identity_for_zero_christoffel(
        self, fibrator, base_metric, dim
    ):
        """Si Γ = 0, el transporte paralelo debe ser aproximadamente I."""
        phase1 = fibrator._Phase1_GeometricFoundation(base_metric)
        zero_torsion = TorsionTensor(components=np.zeros((dim, dim, dim)))
        ctx = phase1.build_geometric_context(zero_torsion.components)
        # Para torsión nula, Γ = ⁰Γ + K = 0 + 0 = 0, transporte ≈ I
        assert np.allclose(ctx.parallel_transport, np.eye(dim), atol=1e-9)

    def test_build_context_returns_all_components(
        self, fibrator, base_metric, valid_torsion
    ):
        phase1 = fibrator._Phase1_GeometricFoundation(base_metric)
        ctx = phase1.build_geometric_context(valid_torsion)
        assert isinstance(ctx, GeometricContext)
        assert ctx.effective_metric.shape[0] == base_metric.shape[0]
        assert ctx.ricci_tensor.shape == base_metric.shape
        assert isinstance(ctx.christoffel, ChristoffelSymbols)
        assert isinstance(ctx.torsion, TorsionTensor)


